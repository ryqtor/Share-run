FROM node:20-alpine

WORKDIR /app

# Accept port as build arg and env var
ARG PORT=3000
ENV PORT=${PORT}

# Install dependencies
COPY package*.json ./
RUN npm install

# Copy application code
COPY . .

# Build the Next.js application
RUN npm run build

# Expose the port
EXPOSE ${PORT}

# Start the production server
CMD ["npm", "start"]
